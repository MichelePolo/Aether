{
  "name": "aether-core",
  "private": true,
  "version": "0.1.14",
  "files": ["dist"],
  "engines": { "node": ">=20" },
  "type": "module",
  "bin": {
    "aether": "dist/cli.cjs"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
